{
  "version": 1,
  "name": "dialogporten",
  "enabled": true,
  "rules": [
    {
      "id": "all",
      "enabled": true,
      "keyMode": "client-id",
      "calls": 100,
      "renewalPeriod": 60,
      "match": {
        "methods": [
          "*"
        ],
        "pathMode": "any"
      }
    },
    {
      "id": "read",
      "enabled": true,
      "keyMode": "client-id",
      "calls": 10000,
      "renewalPeriod": 60,
      "match": {
        "methods": [
          "GET"
        ],
        "pathMode": "prefix",
        "path": "/dialogporten"
      }
    }
  ]
}
