<fragment>
  <choose>
    <when condition="@(!(context.Variables.ContainsKey(&quot;oauthClientId&quot;) &amp;&amp; !string.IsNullOrEmpty((string)context.Variables[&quot;oauthClientId&quot;])))">
      <set-variable name="oauthClientId" value="@{ var authorization = context.Request.Headers.GetValueOrDefault(&quot;Authorization&quot;, &quot;&quot;); if (!string.IsNullOrEmpty(authorization) &amp;&amp; authorization.StartsWith(&quot;Bearer &quot;, StringComparison.OrdinalIgnoreCase)) { var jwt = authorization.Substring(7).AsJwt(); if (jwt != null &amp;&amp; jwt.Claims.ContainsKey(&quot;client_id&quot;)) { return jwt.Claims.GetValueOrDefault(&quot;client_id&quot;, &quot;&quot;); } } return &quot;&quot;; }" />
    </when>
  </choose>
  <choose>
    <when condition="@(!(context.Variables.ContainsKey(&quot;oauthScopes&quot;) &amp;&amp; !string.IsNullOrEmpty((string)context.Variables[&quot;oauthScopes&quot;])))">
      <set-variable name="oauthScopes" value="@{ var authorization = context.Request.Headers.GetValueOrDefault(&quot;Authorization&quot;, &quot;&quot;); if (!string.IsNullOrEmpty(authorization) &amp;&amp; authorization.StartsWith(&quot;Bearer &quot;, StringComparison.OrdinalIgnoreCase)) { var jwt = authorization.Substring(7).AsJwt(); if (jwt != null) { var scopes = jwt.Claims.GetValueOrDefault(&quot;scope&quot;, &quot;&quot;); if (string.IsNullOrEmpty(scopes)) { scopes = jwt.Claims.GetValueOrDefault(&quot;scp&quot;, &quot;&quot;); } if (!string.IsNullOrWhiteSpace(scopes)) { return &quot; &quot; + scopes.Trim() + &quot; &quot;; } } } return &quot;&quot;; }" />
    </when>
  </choose>
  <choose>
    <when condition="@((true &amp;&amp; true &amp;&amp; (((string)context.Variables[&quot;oauthClientId&quot;] == &quot;foobar&quot;))))" />
    <otherwise>
      <choose>
        <when condition="@(!string.IsNullOrEmpty((string)context.Variables[&quot;oauthClientId&quot;]) &amp;&amp; ((context.Request.Method == &quot;POST&quot;) &amp;&amp; context.Request.Url.Path.StartsWith(&quot;/dialogporten/api/v1/orders/&quot;, StringComparison.Ordinal) &amp;&amp; (((string)context.Variables[&quot;oauthClientId&quot;] == &quot;partner-a&quot; || (string)context.Variables[&quot;oauthClientId&quot;] == &quot;partner-b&quot;) &amp;&amp; (((string)context.Variables[&quot;oauthScopes&quot;]).Contains(&quot; orders:admin &quot;, StringComparison.Ordinal) || ((string)context.Variables[&quot;oauthScopes&quot;]).Contains(&quot; orders:write &quot;, StringComparison.Ordinal)))))">
          <rate-limit-by-key calls="300" renewal-period="60" counter-key="@(&quot;dialogporten:partner-write:client-id:&quot; + (string)context.Variables[&quot;oauthClientId&quot;])" retry-after-header-name="Retry-After" />
        </when>
      </choose>
    </otherwise>
  </choose>
</fragment>
