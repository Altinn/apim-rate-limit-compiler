{
  "$schema": "https://raw.githubusercontent.com/Altinn/apim-policy-compiler/main/schemas/rate-limit-v1.schema.json",
  "version": 1,
  "scope": "dialogporten",
  "enabled": true,
  "rules": [
    {
      "id": "default",
      "enabled": true,
      "methods": ["GET", "POST"],
