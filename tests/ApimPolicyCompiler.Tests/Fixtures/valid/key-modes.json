{
  "version": 1,
  "name": "dialogporten",
  "enabled": true,
  "rules": [
    {
      "id": "client",
      "enabled": true,
      "keyMode": "client-id",
      "calls": 10,
      "renewalPeriod": 60,
      "match": {
        "methods": [
          "GET"
        ],
        "pathMode": "prefix",
        "path": "/client"
      }
    },
    {
      "id": "client-ip",
      "enabled": true,
      "keyMode": "client-id-ip",
      "calls": 10,
      "renewalPeriod": 60,
      "match": {
        "methods": [
          "GET"
        ],
        "pathMode": "prefix",
        "path": "/client-ip"
      }
    },
    {
      "id": "client-claim",
      "enabled": true,
      "keyMode": "client-id-claim",
      "keyClaimName": "consumer",
      "calls": 10,
      "renewalPeriod": 60,
      "match": {
        "methods": [
          "GET"
        ],
        "pathMode": "prefix",
        "path": "/client-claim"
      }
    }
  ]
}
