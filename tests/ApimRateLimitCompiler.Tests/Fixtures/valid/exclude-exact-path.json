{
  "version": 1,
  "name": "dialogporten",
  "enabled": true,
  "rules": [
    {
      "id": "all-dialogporten",
      "enabled": true,
      "keyMode": "client-id",
      "calls": 120,
      "renewalPeriod": 60,
      "match": {
        "methods": [
          "*"
        ],
        "pathMode": "prefix",
        "path": "/dialogporten"
      }
    },
    {
      "id": "health-exempt",
      "enabled": true,
      "action": "exclude",
      "match": {
        "methods": [
          "GET"
        ],
        "pathMode": "exact",
        "path": "/dialogporten/health"
      }
    }
  ]
}
