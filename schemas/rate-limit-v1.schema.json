{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Altinn/apim-rate-limit-compiler/main/schemas/rate-limit-v1.schema.json",
  "title": "APIM rate-limit policy configuration v1",
  "description": "Configuration consumed by apim-rate-limit-compiler to generate Azure API Management rate-limit policy fragment XML.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "enabled", "rules"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema reference for editors and CI validation.",
      "const": "https://raw.githubusercontent.com/Altinn/apim-rate-limit-compiler/main/schemas/rate-limit-v1.schema.json"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "enabled": {
      "type": "boolean"
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "enabled",
        "match"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "enabled": {
          "type": "boolean"
        },
        "action": {
          "enum": ["limit", "exclude"],
          "default": "limit"
        },
        "match": {
          "$ref": "#/$defs/match"
        },
        "keyMode": {
          "enum": ["client-id", "client-id-ip"]
        },
        "calls": {
          "type": "integer",
          "minimum": 1
        },
        "renewalPeriod": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        }
      },
      "allOf": [
        {
          "if": {
            "not": {
              "properties": {
                "action": {
                  "const": "exclude"
                }
              },
              "required": ["action"]
            }
          },
          "then": {
            "required": ["keyMode", "calls", "renewalPeriod"]
          }
        }
      ]
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["methods", "pathMode"],
      "properties": {
        "methods": {
          "oneOf": [
            {
              "type": "array",
              "prefixItems": [
                {
                  "const": "*"
                }
              ],
              "items": false,
              "minItems": 1,
              "maxItems": 1
            },
            {
              "type": "array",
              "items": {
                "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS", "TRACE"]
              },
              "minItems": 1,
              "uniqueItems": true
            }
          ]
        },
        "pathMode": {
          "enum": ["any", "exact", "prefix"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "caller": {
          "$ref": "#/$defs/caller"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "pathMode": {
                "enum": ["exact", "prefix"]
              }
            },
            "required": ["pathMode"]
          },
          "then": {
            "required": ["path"]
          }
        }
      ]
    },
    "caller": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "clientIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\S+$"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "anyOf": [
        {
          "required": ["clientIds"]
        },
        {
          "required": ["scopes"]
        }
      ]
    }
  }
}
